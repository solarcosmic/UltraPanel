<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="../styles.css">
    <style>
        /* From https://stackoverflow.com/a/57335917 */
        #container {
            width: 100%;
            display: grid;
            grid-template-areas: "sidebar main";
            grid-template-columns: 200px auto;
        }
        #sidebar {
            grid-area: sidebar;
            height: 100vw;
            background-color: #161616;
            padding: 20px;
        }
        #console {
            grid-area: main;
            height: 100vw;
            background-color: #121212;
        }
        #server-name {
            font-size: 18px;
            font-weight: 600;
            text-overflow: ellipsis;
        }
        #server-ip {
            color: grey;
            text-overflow: ellipsis;
        }
        #console-block {
            width: 500px;
            height: 500px;
            background-color: #121212;
            color: white;
        }
        #console-hint {
            color: grey;
            font-style: italic;
            padding-top: 10px;
        }
        #console-command {
            width: 500px;
            background-color: #121212;
            color: white;
            font-size: 20px;
        }
        #navigation-back {
            background-color: #242424;
            color: white;
            border: none;
            border-radius: 8px;
            width: 100%;
            height: 32px;
            margin-bottom: 10px;
            cursor: pointer;
        }
        #navigation-back:hover {
            background-color: #282828;
        }
        #server-status-main {
            background-color: #242424;
            color: white;
            border: none;
            border-radius: 8px;
            width: 100%;
            height: 32px;
            margin-top: 10px;
            margin-bottom: 10px;
            cursor: pointer;
        }
        #server-status-main[status="start"] {
            background-color: #00210a;
        }
        #server-status-main[status="stop"] {
            background-color: #210000;
        }
        #server-status-restart {
            background-color: #454000;
            color: white;
            border: none;
            border-radius: 8px;
            width: 100%;
            height: 32px;
            margin-top: 10px;
            margin-bottom: 10px;
            cursor: pointer;
        };
    </style>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div id="container">
        <div id="sidebar">
            <button id="navigation-back"><- Back</button>
            <div id="server-name"></div>
            <div id="server-ip">127.0.0.1:25565</div>
            <button id="server-status-main" status="start">Start</button>
            <button id="server-status-restart">Restart</button>
        </div>
        <div id="console">
            <textarea id="console-block" readonly></textarea>
            <input type="text" id="console-command" placeholder="Enter a command..."></input>
            <div id="console-hint">Only showing the last 100 entries.</div>
        </div>
    </div>
    
</body>
<script>
    const socket = io();
    const maxLogCount = 100;
    const server = <%- JSON.stringify(server) %>;
    const logs = <%- JSON.stringify(logs) %>;
    console.log(server);
    document.getElementById("console-block").textContent = logs.split("\n").slice(-100).join("\n");
    document.getElementById("server-name").textContent = server.name;
    const console_logbox = document.getElementById("console-block");
    console_logbox.scrollTop = console_logbox.scrollHeight;
    const console_command = document.getElementById("console-command");
    const navigation_back = document.getElementById("navigation-back");
    const server_status_button = document.getElementById("server-status-main");
    const server_restart_button = document.getElementById("server-status-restart");
    socket.emit("subscribeLogs", server.id);

    console_command.addEventListener("keydown", (e) => {
        if (e.key == "Enter") {
            const cmd = console_command.value.trim();
            if (!cmd) return;
            socket.emit("execCommand", {containerId: server.id, command: cmd});
            console_command.value = "";
        }
    });
    var lines = [];
    socket.on("logs", (data) => {
        lines = lines.concat(data.split("\n"));
        if (lines.length > 100) lines.slice(-maxLogCount);
        console_logbox.value = lines.join("\n");
        console_logbox.scrollTop = console_logbox.scrollHeight;
    })
    socket.on("commandResult", (result) => {
        lines = lines.concat(result.split("\n"));
        if (lines.length > maxLogCount) lines.slice(-maxLogCount);
        console_logbox.value = lines.join("\n");
        console_logbox.scrollTop = console_logbox.scrollHeight;
    });
    socket.on("containerStatus", (data) => {
        // TODO: implement so only one person (auth?) or the valid people can get this because this occurs for every server
        console.log("Event FIRED");
        console.log(data);
        if (data.id == server.id) {
            console.log(`ALERT: DATA CHANGE: ${data.action}`);
            if (data.action == "stop" || data.action == "die") {
                setActionStatus("start");
                println("[UPD] > Server stopped, halted, or terminated");
            } else if (data.action == "start") {
                setActionStatus("stop");
                lines.length = 0; // resets array
                console_logbox.value = "";
                println("[UPD] > Server started");
                socket.emit("subscribeLogs", server.id);
            }
        }
    });

    function println(line) {
        lines.push(line);
        if (lines.length > maxLogCount) lines.slice(-maxLogCount);
        console_logbox.value = lines.join("\n");
        console_logbox.scrollTop = console_logbox.scrollHeight;
    }

    function setActionStatus(status = "start") {
        if (status == "start") {
            server_status_button.textContent = "Start";
        } else if (status == "stop") {
            server_status_button.textContent = "Stop";
        } else {
            return;
        }
        server_status_button.setAttribute("status", status);
    };

    function getActionStatus() {
        return server_status_button.getAttribute("status") || "unknown";
    };

    function getServerStatus(id = server.id) {
        return fetch("/api/server-status/" + id, {
            method: "GET",
            headers: {
                "Content-Type": "application/json"
            }
        })
        .then(response => response.json())
        //.then(data => {
        //    return data;
        //});
    };
    navigation_back.addEventListener("click", () => {
        window.location.href = "/";
    });
    server_restart_button.addEventListener("click", () => {
        updateStatus("restart", server.id); // needs security measure
    })
    document.addEventListener("DOMContentLoaded", () => {
        getServerStatus().then(data => {
            if (data.isRunning) {
                setActionStatus("stop");
            } else {
                setActionStatus("start");
            }
        });
    });
    function updateStatus(statusType, serverId) {
        fetch("/api/send-signal", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({command: statusType, serverId: serverId}),
        })
        .then(response => {
            console.log("Response received");
            //if (response.ok) {
            //    renderServerList();
            //}
        })
        .then(data => console.log(data));
    };
</script>
</html>